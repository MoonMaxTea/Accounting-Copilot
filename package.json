{
  "name": "accounting-copilot",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "pnpm --filter @asd/shared-types build && pnpm -r test",
    "test:rust": "cd app/src-tauri && cargo test",
    "test:all": "pnpm test && pnpm test:rust",
    "build": "pnpm -r build",
    "app:dev": "pnpm --filter @asd/accounting-copilot tauri dev",
    "app:build": "pnpm --filter @asd/accounting-copilot tauri build",
    "pack:build": "bash scripts/pack-build.sh",
    "validate:registry": "bash scripts/validate-registry.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "sharp": "^0.35.2",
    "to-ico": "^1.1.5"
  }
}
